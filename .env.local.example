# Copiá este archivo a .env.local y completá los valores.
# Mientras esté vacío, Plancitos usa los datos de ejemplo (mock).

# --- Google Places (buscador y fotos reales) ---
GOOGLE_PLACES_API_KEY=
NEXT_PUBLIC_USE_REAL_PLACES=false

# --- Login con Google (Auth.js) ---
# AUTH_SECRET: generalo con  npx auth secret   (o  openssl rand -base64 32 )
AUTH_SECRET=
# Credenciales del cliente OAuth de Google (Google Cloud > Credenciales > ID de cliente de OAuth)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
