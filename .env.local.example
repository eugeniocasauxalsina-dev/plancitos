# Copiá este archivo a .env.local y pegá tu clave cuando quieras usar datos reales.
# Mientras esté vacío, Plancitos usa los datos de ejemplo (mock).

# Clave de la API de Google Places (New). Sacala en: https://console.cloud.google.com
GOOGLE_PLACES_API_KEY=

# Poné en "true" para forzar el uso de datos reales (requiere la clave de arriba).
NEXT_PUBLIC_USE_REAL_PLACES=false
